{
  "expo": {
    "name": "PashuSantha",
    "slug": "vikrai-mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/logo.jpg",
    "userInterfaceStyle": "light",
    "scheme": "vikrai",
    "splash": {
      "image": "./assets/logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpg",
        "backgroundColor": "#ffffff"
      },
      "package": "com.koti9032.vikraimobile"
    },
    "web": {
      "favicon": "./assets/logo.jpg",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "57fc057e-f76e-410d-a30f-b68f6a3d65e1"
      }
    }
  }
}
